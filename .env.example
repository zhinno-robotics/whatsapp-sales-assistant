# AI API Configuration (OpenAI-compatible)
# DeepSeek: https://api.deepseek.com/v1
# OpenAI: https://api.openai.com/v1
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=deepseek-chat

# Translation settings
# Auto-detect language and translate; user's native language for understanding
USER_NATIVE_LANG=zh
# Customer target language (replies generated in this language)
CUSTOMER_LANG=en

# Conversation context window (number of recent messages to include)
CONTEXT_WINDOW=10

# WhatsApp phone number for pairing code auth (international format, no symbols)
# Example: 8613800138000 for Chinese number +86 13800138000
WHATSAPP_PHONE_NUMBER=your-phone-number

# License key (provided by vendor)
LICENSE_KEY=

# Session storage path
DATA_PATH=./data
