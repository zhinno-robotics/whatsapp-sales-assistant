{
  "manifest_version": 3,
  "name": "WhatsApp Sales Assistant",
  "version": "1.0.0",
  "description": "AI-powered sales assistant sidebar for WhatsApp Web — translation, suggestions, and smart reply generation.",
  "permissions": [
    "sidePanel",
    "tabs",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "http://localhost:3000/*"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "WhatsApp Sales Assistant"
  }
}
